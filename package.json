{
  "name": "minna-no-recipe",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^22",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "dev:web": "pnpm --filter @minna-no-recipe/web dev",
    "dev:api": "pnpm --filter @minna-no-recipe/api dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "oxlint": "^0.15.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
